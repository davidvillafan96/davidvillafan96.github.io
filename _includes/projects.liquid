{% assign sorted_projects = site.projects | sort: "importance" %}

<div class="w-full flex flex-col items-center space-y-3 my-8 font-sans">
  {% for project in sorted_projects %}
    <a href="{{ project.url | relative_url }}" class="w-full max-w-[750px] block no-underline transition-all duration-200 hover:scale-[1.015] hover:opacity-95">
      
      <div class="w-full text-white px-6 py-3 rounded-full flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 shadow-sm text-center sm:text-left" 
           style="background-color: {{ project.bg_color | default: '#b3b5fc' }}; border: none;">
        
        <span class="font-bold text-base flex items-center justify-center sm:justify-start gap-2">
          {% if project.icon %}
            <i class="{{ project.icon }}"></i>
          {% else %}
            <i class="fa-solid fa-flask"></i>
          {% endif %}
          {{ project.title }}
        </span>
        
        <span class="text-sm font-medium opacity-95 tracking-wide">
          {{ project.description }}
        </span>
        
      </div>

    </a>
  {% endfor %}
</div>
