<!-- News section -->
<section class="news-section">
  {% if site.posts.size > 0 %}
    <h2>Latest News</h2>
    <ul>
    {% for post in site.posts limit: 5 %}
      <li>
        <a href="{{ post.url | relative_url }}">{{ post.title }}</a>
        <span class="date">{{ post.date | date: "%b %d, %Y" }}</span>
      </li>
    {% endfor %}
    </ul>
  {% endif %}
</section>
